{
  "name": "powell-place",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:blog": "node scripts/generate-blog-manifest.mjs",
    "dev": "npm run generate:blog && next dev",
    "build": "npm run generate:blog && next build",
    "preview": "npm run generate:blog && opennextjs-cloudflare build && opennextjs-cloudflare preview --env preview",
    "deploy": "npm run generate:blog && opennextjs-cloudflare build && opennextjs-cloudflare deploy --env production",
    "deploy:preview": "npm run generate:blog && opennextjs-cloudflare build && opennextjs-cloudflare deploy --env preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "lint:eslint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint:eslint:fix": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": "prettier --write"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "gray-matter": "^4.0.3",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0",
    "wrangler": "^4.112.0"
  }
}
